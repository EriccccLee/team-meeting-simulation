# Slack Bot Token (xoxb-로 시작)
# 필요 스코프: users:read, channels:read, channels:history, groups:read, groups:history
SLACK_BOT_TOKEN=xoxb-your-bot-token

# 수집 대상 채널 ID 목록 (쉼표 구분, 채널 ID는 C로 시작)
# 예: SLACK_CHANNELS=C01234567,C08901234
SLACK_CHANNELS=your-channel-id

# 메시지 수집 상한 (Slack API 호출 횟수 제어, 기본 2000)
# 10000 이상은 Rate Limit 위험. 100000은 사용 불가 (시간/비용 문제)
SLACK_MAX_COLLECT=2000

# LLM 분석에 전달할 메시지 수 상한 (기본 100)
# 300까지는 안전, 1000+ 는 컨텍스트 초과 위험
SLACK_MAX_MESSAGES=300
